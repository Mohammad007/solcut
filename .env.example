# ── Copy this file to `.env` and fill in real values for production ──
# In dev, the defaults below keep everything mocked (no external accounts needed).

SECRET_KEY=dev-secret-key-change-me
JWT_SECRET_KEY=jwt-secret-key-change-me

# OTP provider: 'mock' (dev), 'twilio', or 'msg91'
# In 'mock' mode the OTP is always 123456 and is also printed to the console.
OTP_PROVIDER=mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SID=
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# Firebase Cloud Messaging — leave path empty/missing to mock (logs to console)
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# Razorpay — leave empty to mock (orders/payments auto-succeed)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Admin panel login (session based)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=slotcut@admin123

# Public base URL (used to build absolute upload/image URLs)
BASE_URL=http://localhost:5000
